<header
    class="bg-gradient-to-r from-slate-800 to-gray-900 text-white py-4 shadow-xl fixed w-full top-0 z-50 backdrop-blur-sm bg-opacity-95"
>
    <div
        class="container mx-auto flex flex-wrap items-center justify-between px-4 md:px-6"
    >
        <!-- Logo -->
        <div class="flex items-center space-x-3">
            <a href="/">
                <img
                    src="/logo.png"
                    alt="Softechperu Logo"
                    class="h-12 w-auto transition-transform duration-300 hover:scale-110"
                />
            </a>
        </div>

        <!-- Checkbox para activar el menú -->
        <input type="checkbox" id="menu-toggle" class="hidden peer" />

        <!-- Menú hamburguesa -->
        <label
            for="menu-toggle"
            class="md:hidden text-white focus:outline-none p-2 rounded-full bg-gray-700 hover:bg-gray-600 transition-colors duration-300 cursor-pointer"
        >
            <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16m-7 6h7"
                ></path>
            </svg>
        </label>

        <!-- Menú de navegación -->
        <nav
            class="hidden peer-checked:flex w-full md:flex md:w-auto flex-col md:flex-row items-center md:space-x-6 mt-4 md:mt-0"
        >
            <a
                href="/"
                class="px-3 py-2 rounded-lg hover:bg-gray-700 transition-all duration-300 flex items-center"
            >
                <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 12l2-2m0 0l7-7 7 7m-14 0l2 2m0 0l7 7 7-7"
                    ></path>
                </svg>
                Inicio
            </a>
            <a
                href="/nosotros"
                class="px-3 py-2 rounded-lg hover:bg-gray-700 transition-all duration-300 flex items-center"
            >
                <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path>
                </svg>
                Nosotros
            </a>
            <a
                href="/contacto"
                class="px-3 py-2 rounded-lg hover:bg-gray-700 transition-all duration-300 flex items-center"
            >
                <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                </svg>
                Contacto
            </a>
            <a
                href="/servicios"
                class="px-3 py-2 rounded-lg hover:bg-gray-700 transition-all duration-300 flex items-center"
            >
                <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                    ></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Servicios
            </a>
        </nav>

        <!-- Botón de contacto -->
        <div class="hidden lg:block">
            <a
        href="https://wa.me/51966963210?text=Solicito%20más%20información%20sobre%20sus%20servicios"
        target="_blank"
        class="relative inline-block px-6 sm:px-8 py-2 sm:py-3 bg-teal-600 text-white text-xs sm:text-sm md:text-base font-semibold rounded-full hover:bg-teal-700 transition-all duration-300 shadow-lg hover:shadow-teal-500/50 overflow-hidden group w-full sm:w-auto"
    >
        Contáctanos
    </a>
        </div>
    </div>
</header>
