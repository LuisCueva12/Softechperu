---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<!-- HERO SECTIÓN -->
	<section
		class="w-full bg-neutral-950 text-white pt-24 sm:pt-28 md:pt-32 lg:pt-36 pb-16 sm:pb-20 md:pb-24 lg:pb-28 relative overflow-hidden"
	>
		<!-- Fondo dinámico con gradiente animado y formas geométricas -->
		<div
			class="absolute inset-0 bg-gradient-to-tr from-teal-900 via-blue-950 to-violet-900 opacity-95 animate-gradient"
		>
			<!-- Líneas y formas geométricas modernas -->
			<div
				class="absolute inset-0 bg-[linear-gradient(45deg,rgba(45,212,191,0.1)_1px,transparent_1px,transparent_10px),linear-gradient(-45deg,rgba(139,92,246,0.1)_1px,transparent_1px,transparent_10px)] bg-[size:20px_20px] animate-gradient-lines"
			>
			</div>
			<div
				class="absolute w-40 h-40 sm:w-56 sm:h-56 md:w-72 md:h-72 lg:w-96 lg:h-96 bg-teal-500/20 rounded-full blur-3xl top-1/4 left-1/4 animate-pulse-slow"
			>
			</div>
			<div
				class="absolute w-32 h-32 sm:w-48 sm:h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 bg-violet-500/20 rounded-full blur-3xl bottom-1/3 right-1/3 animate-pulse-slow"
			>
			</div>
		</div>

		<!-- Contenedor principal -->
		<div
			class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col lg:flex-row items-center gap-8 sm:gap-10 lg:gap-12"
		>
			<!-- Texto principal -->
			<div
				class="w-full lg:w-1/2 space-y-6 sm:space-y-8 animate-fade-in-down"
			>
				<!-- Etiqueta decorativa con palabra clave SEO -->
				<div
					class="inline-flex items-center px-3 py-1 sm:px-4 sm:py-2 bg-teal-600/30 text-teal-100 rounded-full text-[0.65rem] sm:text-xs md:text-sm font-medium tracking-wider uppercase shadow-md"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4 sm:h-5 sm:w-5 mr-1 sm:mr-2"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M13 10V3L4 14h7v7l9-11h-7z"></path>
					</svg>
					Desarrollo Web Innovador
				</div>

				<!-- Título principal con palabras clave SEO -->
				<h1
					class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-black leading-tight tracking-tight text-white drop-shadow-lg"
				>
					Soluciones Digitales para el
					<span
						class="bg-clip-text text-transparent bg-gradient-to-r from-teal-300 to-violet-300"
						>Futuro de tu Negocio</span
					>
				</h1>

				<!-- Descripción con palabras clave SEO (letra más pequeña) -->
				<p
					class="text-[0.65rem] sm:text-xs md:text-sm lg:text-base xl:text-lg text-blue-50 max-w-lg leading-relaxed drop-shadow-md"
				>
					En <strong>Softechperu</strong>, ofrecemos <strong
						>tecnología innovadora</strong
					> y <strong>desarrollo web</strong> a medida para impulsar tu
					éxito. Nuestras <strong>soluciones digitales</strong>, desde <strong
						>desarrollo de software</strong
					> hasta <strong>consultoría tecnológica</strong>, optimizan
					tu presencia online.
				</p>

				<!-- Botones CTA Ajustados -->
				<div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
					<a
						href="/contacto"
						class="relative inline-block px-6 sm:px-8 py-2 sm:py-3 bg-teal-600 text-white text-xs sm:text-sm md:text-base font-semibold rounded-full hover:bg-teal-700 transition-all duration-300 shadow-lg hover:shadow-teal-500/50 overflow-hidden group w-full sm:w-auto"
					>
						<span
							class="absolute inset-0 bg-gradient-to-r from-teal-400 to-purple-400 opacity-0 group-hover:opacity-30 transition-opacity duration-300"
						></span>
						<span class="relative z-10">Contáctanos</span>
					</a>
					<a
						href="/servicios"
						class="inline-block px-6 sm:px-8 py-2 sm:py-3 bg-transparent border-2 border-white text-white text-xs sm:text-sm md:text-base font-semibold rounded-full hover:bg-white hover:text-teal-900 transition-all duration-300 shadow-md hover:shadow-purple-500/50 w-full sm:w-auto"
					>
						Descubre Nuestros Servicios
					</a>
				</div>
			</div>

			<!-- Espacio para la imagen (más grande aún) -->
			<div
				class="w-full lg:w-1/2 flex justify-center items-center mt-8 lg:mt-0 animate-fade-in-up"
			>
				<div
					class="relative bg-gradient-to-br from-teal-600 to-blue-800 p-2 sm:p-3 lg:p-4 rounded-2xl shadow-2xl transform hover:scale-105 transition-all duration-500"
				>
					<img
						src="/images/sistemas-a-medida.png"
						alt="Soluciones Digitales Innovadoras"
						class="w-full max-w-[360px] sm:max-w-[400px] md:max-w-[480px] lg:max-w-[560px] h-auto rounded-xl bg-neutral-800"
						onerror="this.onerror=null; this.src='/api/placeholder/560/560'; this.alt='Ilustración tecnológica'"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Sección Servicios (Fondo oscuro con ondas) -->
	<section
		class="w-full bg-white text-gray-900 py-20 relative overflow-hidden"
	>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="text-center mb-16">
				<div
					class="inline-flex items-center justify-center p-2 bg-blue-900 bg-opacity-50 rounded-lg mb-4"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-8 w-8 text-blue-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
						></path>
					</svg>
				</div>
				<h2
					class="text-4xl font-bold tracking-tight animate-pulse-text"
				>
					Nuestros Servicios
				</h2>
				<p class="mt-4 text-lg text-gray-700 max-w-2xl mx-auto">
					Ofrecemos soluciones innovadoras para potenciar tu negocio
					con tecnología de vanguardia.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Servicio 1: Desarrollo Web -->
				<div
					class="bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-blue-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-blue-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-blue-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3 text-gray-900">
							Desarrollo Web
						</h3>
						<p class="text-gray-700">
							Diseñamos y desarrollamos plataformas web modernas,
							rápidas y optimizadas que fortalecen tu presencia
							digital y mejoran la experiencia de tus clientes.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Sitios web responsive para todos los dispositivos
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Aplicaciones web progresivas para mayor accesibilidad
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Optimización SEO avanzada para mejor posicionamiento
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Integración con herramientas de analítica web
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Diseño personalizado según tu marca
							</li>
						</ul>
					</div>
				</div>

				<!-- Servicio 2: Desarrollo de Software -->
				<div
					class="bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-green-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-green-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-green-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3 text-gray-900">
							Desarrollo de Software
						</h3>
						<p class="text-gray-700">
							Creamos soluciones de software a medida que
							automatizan procesos y optimizan la gestión de tu
							empresa, adaptadas a tus necesidades específicas.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Sistemas de gestión de inventario personalizados
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Herramientas de CRM para seguimiento de clientes
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Automatización de tareas repetitivas
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Integración con plataformas existentes
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Soporte continuo y actualizaciones
							</li>
						</ul>
					</div>
				</div>

				<!-- Servicio 3: Soporte Técnico -->
				<div
					class="bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-purple-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-purple-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-purple-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3 text-gray-900">
							Soporte Técnico
						</h3>
						<p class="text-gray-700">
							Brindamos asistencia rápida y confiable para
							mantener tus sistemas operativos y resolver
							cualquier problema técnico con eficiencia.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Soporte técnico 24/7 por múltiples canales
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Mantenimiento preventivo de sitios y software
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Resolución rápida de fallos técnicos
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Asesoría para optimizar tus herramientas
							</li>
							<li class="flex items-center text-sm text-gray-600">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Actualizaciones regulares incluidas
							</li>
						</ul>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a
					href="/servicios"
					class="inline-block bg-blue-600 text-white px-8 py-4 rounded-lg hover:bg-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105"
				>
					Ver todos los servicios
				</a>
			</div>
		</div>
	</section>

	<!-- Sección de Proyectos: -->
	<section
		class="w-full bg-neutral-950 text-white py-12 sm:py-16 md:py-20 lg:py-24 relative overflow-hidden"
	>
		<!-- Fondo dinámico de la sección -->
		<div
			class="absolute inset-0 bg-gradient-to-tr from-teal-900 via-blue-950 to-violet-900 opacity-95 animate-gradient"
		>
			<!-- Líneas y formas geométricas sutiles -->
			<div
				class="absolute inset-0 bg-[linear-gradient(45deg,rgba(45,212,191,0.1)_1px,transparent_1px,transparent_10px),linear-gradient(-45deg,rgba(139,92,246,0.1)_1px,transparent_1px,transparent_10px)] bg-[size:20px_20px] animate-gradient-lines"
			>
			</div>
			<div
				class="absolute w-40 h-40 sm:w-56 sm:h-56 md:w-72 md:h-72 lg:w-96 lg:h-96 bg-teal-500/20 rounded-full blur-3xl top-1/4 left-1/4 animate-pulse-slow"
			>
			</div>
			<div
				class="absolute w-32 h-32 sm:w-48 sm:h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 bg-violet-500/20 rounded-full blur-3xl bottom-1/3 right-1/3 animate-pulse-slow"
			>
			</div>
		</div>

		<!-- Contenedor principal -->
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="text-center mb-8 sm:mb-12">
				<div
					class="inline-flex items-center justify-center p-2 bg-teal-500/30 rounded-full mb-4 transition-transform duration-300 hover:scale-105"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-6 w-6 sm:h-8 sm:w-8 text-teal-300"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
						></path>
					</svg>
				</div>
				<h2
					class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white animate-fade-in-down"
				>
					Proyectos Destacados
				</h2>
				<p
					class="mt-4 text-sm sm:text-base md:text-lg text-teal-100 max-w-2xl mx-auto transition-opacity duration-500 hover:opacity-90"
				>
					Descubre cómo hemos transformado negocios con soluciones
					tecnológicas innovadoras y personalizadas.
				</p>
			</div>

			<!-- Tarjetas de proyectos -->
			<div
				class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6"
			>
				<!-- Proyecto 1 -->
				<div
					class="bg-gradient-to-br from-gray-800/50 to-gray-900/50 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 border border-teal-500/20"
