---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<section
		class="w-full bg-white text-gray-900 py-12 md:py-16 lg:py-20 relative overflow-hidden"
	>
		<div
			class="absolute inset-0 bg-gradient-to-br from-emerald-50 via-white to-blue-50 opacity-70"
		>
		</div>

		<div
			class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12"
		>
			<!-- Texto e Información -->
			<div class="w-full md:w-1/2 space-y-6 animate-fade-in-left">
				<div
					class="inline-block p-2 bg-emerald-100 rounded-lg text-emerald-600 mb-4"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-6 w-6 sm:h-8 sm:w-8"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
						></path>
					</svg>
				</div>

				<h1
					class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-wide"
				>
					Impulsa tu Negocio con Tecnología Inteligente
				</h1>

				<p
					class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-600 max-w-xl"
				>
					Combinamos innovación y eficiencia para brindarte soluciones
					digitales de alto impacto. Nos especializamos en desarrollo
					de software personalizado para empresas visionarias.
				</p>

				<div class="pt-4 space-y-4">
					<div class="flex items-center">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5 sm:h-6 sm:w-6 text-emerald-500 mr-3"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
							></path>
						</svg>
						<p
							class="text-sm sm:text-base md:text-lg text-gray-700"
						>
							Desarrollo a la medida
						</p>
					</div>
					<div class="flex items-center">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5 sm:h-6 sm:w-6 text-emerald-500 mr-3"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
							></path>
						</svg>
						<p
							class="text-sm sm:text-base md:text-lg text-gray-700"
						>
							Seguridad de primer nivel
						</p>
					</div>
					<div class="flex items-center">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5 sm:h-6 sm:w-6 text-emerald-500 mr-3"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
						<p
							class="text-sm sm:text-base md:text-lg text-gray-700"
						>
							Rendimiento optimizado
						</p>
					</div>
				</div>

				<div class="pt-6 flex flex-col sm:flex-row gap-4">
					<a
						href="/contacto"
						class="bg-emerald-600 text-white px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-lg rounded-lg hover:bg-emerald-700 transition-all duration-300 shadow-md hover:shadow-xl transform hover:translate-y-1 w-full sm:w-auto"
					>
						Contáctanos
					</a>
					<a
						href="/servicios"
						class="bg-white text-emerald-600 border-2 border-emerald-600 px-6 py-3 sm:px-8 sm:py-4 text-sm sm:text-lg rounded-lg hover:bg-emerald-50 transition-all duration-300 shadow-sm hover:shadow-md transform hover:translate-y-1 w-full sm:w-auto"
					>
						Ver servicios
					</a>
				</div>
			</div>

			<!-- Imagen o gráfico -->
			<div class="w-full md:w-1/2 animate-fade-in-right mt-8 md:mt-0">
				<div class="relative">
					<div
						class="absolute -left-4 -top-4 w-12 h-12 sm:w-20 sm:h-20 bg-blue-500 rounded-full opacity-20"
					>
					</div>
					<div
						class="absolute -right-6 -bottom-6 w-16 h-16 sm:w-32 sm:h-32 bg-emerald-500 rounded-full opacity-20"
					>
					</div>
					<div
						class="bg-gradient-to-br from-emerald-500 to-blue-600 p-2 sm:p-2 rounded-lg sm:rounded-xl shadow-lg"
					>
						<img
							src="/images/hero-illustration.png"
							alt="Tecnología Inteligente"
							class="w-full h-auto rounded-md sm:rounded-lg bg-white"
							onerror="this.onerror=null; this.src='/api/placeholder/600/400'; this.alt='Ilustración de tecnología'"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Sección Servicios (Fondo oscuro con ondas) -->
	<section
		class="w-full bg-gray-900 text-white py-20 relative overflow-hidden"
	>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="text-center mb-16">
				<div
					class="inline-flex items-center justify-center p-2 bg-blue-900 bg-opacity-50 rounded-lg mb-4"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-8 w-8 text-blue-400"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
						></path>
					</svg>
				</div>
				<h2
					class="text-4xl font-bold tracking-tight animate-pulse-text"
				>
					Nuestros Servicios
				</h2>
				<p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">
					Ofrecemos soluciones innovadoras para potenciar tu negocio
					con tecnología de vanguardia.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div
					class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-blue-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-blue-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-blue-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3">
							Desarrollo Web
						</h3>
						<p class="text-gray-400">
							Creamos plataformas web modernas, rápidas y
							optimizadas para tu negocio con experiencias de
							usuario excepcionales.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Sitios web responsive
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Aplicaciones web progresivas
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-blue-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Optimización SEO
							</li>
						</ul>
					</div>
				</div>

				<div
					class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-green-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-green-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-green-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3">
							Seguridad Digital
						</h3>
						<p class="text-gray-400">
							Protegemos tu empresa con soluciones de
							ciberseguridad avanzadas contra amenazas modernas.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Evaluación de vulnerabilidades
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Cifrado de datos
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-green-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Monitoreo continuo
							</li>
						</ul>
					</div>
				</div>

				<div
					class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2"
				>
					<div class="h-2 bg-purple-500"></div>
					<div class="p-8">
						<div
							class="flex items-center justify-center w-16 h-16 rounded-full bg-purple-600 bg-opacity-20 mb-6"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-8 w-8 text-purple-500"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
								></path>
							</svg>
						</div>
						<h3 class="text-2xl font-semibold mb-3">
							Inteligencia Artificial
						</h3>
						<p class="text-gray-400">
							Automatizamos procesos y mejoramos la toma de
							decisiones con soluciones de IA personalizadas.
						</p>
						<ul class="mt-4 space-y-2">
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Análisis predictivo
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Chatbots inteligentes
							</li>
							<li class="flex items-center text-sm text-gray-400">
								<svg
									class="h-4 w-4 mr-2 text-purple-400"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M5 13l4 4L19 7"></path>
								</svg>
								Sistemas de recomendación
							</li>
						</ul>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a
					href="/servicios"
					class="inline-block bg-blue-600 text-white px-8 py-4 rounded-lg hover:bg-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105"
				>
					Ver todos los servicios
				</a>
			</div>
		</div>
	</section>

	<!-- Nueva Sección: Sobre Nosotros (Fondo blanco) -->
	<section class="w-full bg-white py-20 relative overflow-hidden">
		<div
			class="absolute right-0 top-0 h-full w-1/2 bg-gray-50 clip-diagonal hidden lg:block"
		>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<div class="flex flex-col lg:flex-row items-center gap-12">
				<div class="lg:w-1/2 animate-fade-in-left">
					<div class="relative">
						<div
							class="absolute -left-6 -top-6 w-20 h-20 bg-emerald-500 rounded-full opacity-20"
						>
						</div>
						<div
							class="absolute -right-6 -bottom-6 w-20 h-20 bg-blue-500 rounded-full opacity-20"
						>
						</div>
						<img
							src="/images/hero-illustration.png"
							alt="Nuestro equipo"
							class="w-full h-auto rounded-lg shadow-xl"
							onerror="this.onerror=null; this.src='/api/placeholder/600/400'; this.alt='Imagen del equipo'"
						/>
					</div>
				</div>

				<div class="lg:w-1/2 animate-fade-in-right">
					<div
						class="inline-flex items-center justify-center p-2 bg-emerald-100 rounded-lg mb-4"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-8 w-8 text-emerald-600"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
							></path>
						</svg>
					</div>

					<h2 class="text-4xl font-bold text-gray-900 mb-6">
						¿Quiénes Somos?
					</h2>

					<p class="text-lg text-gray-600 mb-6">
						Somos un equipo de profesionales apasionados por la
						tecnología con más de 10 años de experiencia
						desarrollando soluciones digitales innovadoras para
						empresas de todos los tamaños.
					</p>

					<p class="text-lg text-gray-600 mb-6">
						Nuestra misión es transformar ideas en soluciones
						digitales que impulsen el crecimiento de tu negocio,
						combinando creatividad, tecnología y estrategia.
					</p>

					<div class="grid grid-cols-2 gap-4 mt-8">
						<div class="flex items-center space-x-2">
							<div
								class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center"
							>
								<span class="text-blue-600 text-xl font-bold"
									>10+</span
								>
							</div>
							<div>
								<p class="text-sm text-gray-500">
									Años de experiencia
								</p>
							</div>
						</div>

						<div class="flex items-center space-x-2">
							<div
								class="flex-shrink-0 w-12 h-12 rounded-full bg-green-100 flex items-center justify-center"
							>
								<span class="text-green-600 text-xl font-bold"
									>50+</span
								>
							</div>
							<div>
								<p class="text-sm text-gray-500">
									Proyectos completados
								</p>
							</div>
						</div>

						<div class="flex items-center space-x-2">
							<div
								class="flex-shrink-0 w-12 h-12 rounded-full bg-purple-100 flex items-center justify-center"
							>
								<span class="text-purple-600 text-xl font-bold"
									>20+</span
								>
							</div>
							<div>
								<p class="text-sm text-gray-500">
									Profesionales
								</p>
							</div>
						</div>

						<div class="flex items-center space-x-2">
							<div
								class="flex-shrink-0 w-12 h-12 rounded-full bg-yellow-100 flex items-center justify-center"
							>
								<span class="text-yellow-600 text-xl font-bold"
									>98%</span
								>
							</div>
							<div>
								<p class="text-sm text-gray-500">
									Clientes satisfechos
								</p>
							</div>
						</div>
					</div>

					<div class="mt-8">
						<a
							href="/nosotros"
							class="inline-flex items-center text-emerald-600 font-semibold hover:text-emerald-700 transition-colors"
						>
							Conoce más sobre nosotros
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-5 w-5 ml-2"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section
		class="w-full bg-emerald-50 text-gray-900 py-12 md:py-16 lg:py-20 relative overflow-hidden"
	>
		<div
			class="absolute inset-0 bg-gradient-to-tl from-blue-50 via-emerald-50 to-white opacity-50"
		>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
			<h2
