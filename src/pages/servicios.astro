---
// src/pages/servicios.astro
import Layout from "../layouts/Layout.astro"; // Asumiendo un layout base
---

<Layout title="Servicios - Softechperu">
    <!-- Hero Section de Servicios (Fondo oscuro) -->
    <section
        class="w-full bg-neutral-950 text-white pt-24 sm:pt-28 md:pt-32 lg:pt-36 pb-16 sm:pb-20 md:pb-24 lg:pb-28 relative overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-gradient-to-tr from-teal-900 via-blue-950 to-violet-900 opacity-95"
        >
        </div>
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center"
        >
            <h1
                class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black leading-tight tracking-tight text-white drop-shadow-lg"
            >
                Nuestros <span
                    class="bg-clip-text text-transparent bg-gradient-to-r from-teal-300 to-violet-300"
                    >Servicios</span
                >
            </h1>
            <p
                class="mt-4 text-sm sm:text-base md:text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed"
            >
                Soluciones digitales innovadoras para llevar tu negocio al
                siguiente nivel.
            </p>
        </div>
    </section>

    <!-- Lista de Servicios (Fondo blanco) -->
    <section class="w-full py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2
                class="text-2xl sm:text-3xl md:text-4xl font-bold text-center text-neutral-900 mb-8 sm:mb-12"
            >
                ¿Qué podemos hacer por ti?
            </h2>
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8"
            >
                <!-- Servicio 1 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-9v18"
                            ></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Desarrollo Web a Medida
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Sitios web únicos, optimizados y adaptados a tus
                        objetivos.
                    </p>
                </div>

                <!-- Servicio 2 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Desarrollo de Aplicaciones
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Apps móviles y web con tecnología de punta.
                    </p>
                </div>

                <!-- Servicio 3 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Consultoría Tecnológica
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Estrategias digitales para optimizar tu negocio.
                    </p>
                </div>

                <!-- Servicio 4 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                            ></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Mantenimiento y Soporte
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Mantén tus plataformas siempre al día y seguras.
                    </p>
                </div>

                <!-- Servicio 5 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm0 0c0 2.21-1.79 4-4 4s-4-1.79-4-4m8 4H5"
                            ></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Diseño UI/UX
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Interfaces atractivas y funcionales para tus usuarios.
                    </p>
                </div>

                <!-- Servicio 6 -->
                <div
                    class="bg-gradient-to-br from-gray-50 to-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 border border-teal-100"
                >
                    <div class="flex items-center gap-4">
                        <svg
                            class="w-12 h-12 text-teal-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 9l3-3 3 3m0 6l-3 3-3-3m-5 3h16"></path>
                        </svg>
                        <h3
                            class="text-lg sm:text-xl font-semibold text-teal-900"
                        >
                            Optimización SEO
                        </h3>
                    </div>
                    <p
                        class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed"
                    >
                        Mejora tu visibilidad en buscadores con SEO avanzado.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA con Formulario (Fondo oscuro) -->
    <section
        id="contacto"
        class="w-full py-12 bg-neutral-950 text-white relative overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-gradient-to-tr from-teal-900 via-blue-950 to-violet-900 opacity-95"
        >
        </div>
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center"
        >
            <h2
                class="text-2xl sm:text-3xl md:text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-teal-300 to-violet-300 mb-4"
            >
                Cotiza tu Proyecto Hoy
            </h2>
            <p
                class="text-sm sm:text-base md:text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed mb-8"
            >
                Completa el formulario y empecemos a construir tu solución
                digital.
            </p>
            <form
                action="/api/contacto"
                method="POST"
                class="max-w-lg mx-auto space-y-4"
            >
                <div>
                    <input
                        type="text"
                        name="name"
                        placeholder="Tu nombre"
                        required
                        class="w-full px-4 py-3 bg-white/10 border border-teal-500/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:border-teal-500 transition-all duration-300"
                    />
                </div>
                <div>
                    <input
                        type="email"
                        name="email"
                        placeholder="Tu correo"
                        required
                        class="w-full px-4 py-3 bg-white/10 border border-teal-500/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:border-teal-500 transition-all duration-300"
                    />
                </div>
                <div>
                    <textarea
                        name="message"
                        placeholder="Cuéntanos sobre tu proyecto"
                        rows="4"
                        required
                        class="w-full px-4 py-3 bg-white/10 border border-teal-500/20 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:border-teal-500 transition-all duration-300"
                    ></textarea>
                </div>
                <button
                    type="submit"
                    class="w-full px-6 py-3 bg-gradient-to-r from-teal-600 to-violet-600 text-white text-sm sm:text-base font-semibold rounded-full hover:from-teal-700 hover:to-violet-700 transition-all duration-300 shadow-lg hover:shadow-teal-500/50"
                >
                    Enviar Cotización
                </button>
            </form>
        </div>
    </section>

    <!-- Sección de Planes de Desarrollo en WordPress (Fondo Blanco) -->
    <section class="w-full py-12 bg-white text-neutral-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 sm:mb-6">
                Planes de Desarrollo en WordPress
            </h2>
            <p
                class="text-sm sm:text-base md:text-lg text-gray-700 max-w-2xl mx-auto leading-relaxed mb-8"
            >
                Elige el plan que mejor se adapte a tu negocio y crea una
                presencia profesional en línea.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
                <!-- Plan Básico -->
                <div
                    class="border border-gray-300 shadow-lg rounded-xl p-6 text-center bg-gray-50
                        transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-2xl"
                >
                    <h3 class="text-lg sm:text-xl font-semibold text-teal-700">
                        Plan Básico
                    </h3>
                    <p class="mt-2 text-sm sm:text-base text-gray-700">
                        Ideal para emprendedores y pequeñas empresas.
                    </p>
                    <div
                        class="text-3xl sm:text-4xl font-bold text-teal-600 my-4"
                    >
                        S/350
                    </div>
                    <ul
                        class="text-sm sm:text-base text-gray-600 space-y-2 mb-6"
                    >
                        <li>✔️ 5 páginas básicas</li>
                        <li>✔️ Diseño responsive</li>
                        <li>✔️ Optimización SEO inicial</li>
                        <li>✔️ Integración con redes sociales</li>
                        <li>✔️ Soporte por 1 mes</li>
                    </ul>
                    <a
                        href="#"
                        class="inline-block w-full bg-teal-600 text-white py-3 rounded-lg hover:bg-teal-700 transition"
                    >
                        Elegir Plan
                    </a>
                </div>

                <!-- Plan Profesional -->
                <div
                    class="border border-teal-500 shadow-lg rounded-xl p-6 text-center bg-white ring-2 ring-teal-500
                        transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-2xl"
                >
                    <h3 class="text-lg sm:text-xl font-semibold text-teal-700">
                        Plan Profesional
                    </h3>
                    <p class="mt-2 text-sm sm:text-base text-gray-700">
                        Para empresas que necesitan más funcionalidades.
                    </p>
                    <div
                        class="text-3xl sm:text-4xl font-bold text-teal-600 my-4"
                    >
                        S/700
                    </div>
                    <ul
                        class="text-sm sm:text-base text-gray-600 space-y-2 mb-6"
                    >
                        <li>✔️ 10 páginas personalizadas</li>
                        <li>✔️ Diseño avanzado</li>
                        <li>✔️ SEO optimizado</li>
                        <li>✔️ Blog integrado</li>
                        <li>✔️ Soporte por 3 meses</li>
                    </ul>
                    <a
                        href="#"
                        class="inline-block w-full bg-teal-600 text-white py-3 rounded-lg hover:bg-teal-700 transition"
                    >
                        Elegir Plan
                    </a>
                </div>

                <!-- Plan Empresarial -->
                <div
                    class="border border-gray-300 shadow-lg rounded-xl p-6 text-center bg-gray-50
                        transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-2xl"
                >
                    <h3 class="text-lg sm:text-xl font-semibold text-teal-700">
                        Plan Empresarial
                    </h3>
                    <p class="mt-2 text-sm sm:text-base text-gray-700">
                        Solución completa para negocios en crecimiento.
                    </p>
                    <div
                        class="text-3xl sm:text-4xl font-bold text-teal-600 my-4"
                    >
                        S/1130
                    </div>
                    <ul
                        class="text-sm sm:text-base text-gray-600 space-y-2 mb-6"
                    >
                        <li>✔️ 20+ páginas personalizadas</li>
                        <li>✔️ Diseño premium y a medida</li>
                        <li>✔️ SEO avanzado</li>
                        <li>✔️ Tienda en línea (WooCommerce)</li>
                        <li>✔️ Soporte por 6 meses</li>
                    </ul>
                    <a
                        href="#"
                        class="inline-block w-full bg-teal-600 text-white py-3 rounded-lg hover:bg-teal-700 transition"
                    >
                        Elegir Plan
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
